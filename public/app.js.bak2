const orderStatusEl = document.querySelector("[data-order-status]");
const orderUpdatedEl = document.querySelector("[data-order-updated]");
// ---------- products load ----------
async function loadProducts() {
  // 1) Try server (shared catalog + images)
  try {
    const r = await fetch(`${API_BASE}/api/products`, { cache: "no-store" });
    const data = await r.json().catch(() => null);
    const arr = Array.isArray(data?.products) ? data.products : null;
    if (arr && arr.length) {
      products = arr;
      localStorage.setItem(STORAGE.PRODUCTS, JSON.stringify(products));
      return;
    }
  } catch {}

  // 2) Fallback to local cache
  const fromLs = localStorage.getItem(STORAGE.PRODUCTS);
  if (fromLs) {
    try {
      products = JSON.parse(fromLs);
      if (Array.isArray(products) && products.length) return;
    } catch {}
  }

  // 3) Seed
  const r2 = await fetch("./products.seed.json", { cache: "no-store" });
  products = await r2.json();
  localStorage.setItem(STORAGE.PRODUCTS, JSON.stringify(products));
}

// ---------- zones load ----------
async function loadZones() {
  try {
    const r = await fetch(`${API_BASE}/api/zones`, { cache: "no-store" });
    const data = await r.json().catch(() => null);
    zones = Array.isArray(data?.zones) ? data.zones : [];
  } catch {
    zones = [];
  }
}

// ---------- qty controls on cards (+ / −) ----------
let qtyControlsWired = false;

function wireQtyControls() {
  if (qtyControlsWired) return;
  qtyControlsWired = true;

  // small helper
  const esc = (s) => (window.CSS && CSS.escape ? CSS.escape(String(s)) : String(s).replace(/["\\]/g, "\\$&"));

  // "open steppers" state only for cards
  const OPEN = new Set();
  window.__OPEN_CARD_STEPPERS = OPEN;

  function getQty(id) {
    const cart = loadCart();
    return Number(cart[id] || 0);
  }

  function syncCard(id) {
    const qty = getQty(id);
    const sel = `[data-qty-root][data-id="${esc(id)}"]`;
    document.querySelectorAll(sel).forEach((root) => {
      const addBtn = root.querySelector('[data-action="card-open"]');
      const stepper = root.querySelector("[data-stepper]");
      const qtyEl = root.querySelector(`[data-qty-for="${esc(id)}"]`);

      if (qtyEl) qtyEl.textContent = String(qty);

      // If qty is 0 => always collapsed
      if (qty <= 0) {
        OPEN.delete(id);
        if (addBtn) addBtn.hidden = false;
        if (stepper) stepper.hidden = true;
        return;
      }

      // qty > 0 => show stepper only if user just interacted
      const isOpen = OPEN.has(id);
      if (addBtn) addBtn.hidden = isOpen;
      if (stepper) stepper.hidden = !isOpen;
    });
  }

  function syncAllCards() {
    const cart = loadCart();
    Object.keys(cart || {}).forEach((id) => syncCard(id));
    // also sync visible cards with qty 0 (ensure plus visible)
    document.querySelectorAll("[data-qty-root][data-id]").forEach((root) => {
      const id = root.getAttribute("data-id");
      if (!id) return;
      if (getQty(id) <= 0) syncCard(id);
    });
  }

  // expose for other code (after re-render)
  window.__syncCardQty = syncCard;
  window.__syncAllCardQty = syncAllCards;
  window.__openCardStepper = (id) => {
    OPEN.add(String(id));
    syncCard(String(id));
  };
  window.__closeAllCardSteppers = () => {
    OPEN.clear();
    syncAllCards();
  };

  // Collapse steppers on scroll (mobile UX)
  let scrollT = null;
  window.addEventListener(
    "scroll",
    () => {
      if (!window.matchMedia("(max-width: 760px)").matches) return;
      if (scrollT) clearTimeout(scrollT);
      scrollT = setTimeout(() => {
        OPEN.clear();
        syncAllCards();
      }, 180);
    },
    { passive: true }
  );

  // Delegate clicks (works after any re-render)
  document.addEventListener("click", (e) => {
    const btn = e.target.closest("[data-action][data-id]");
    if (!btn) return;

    const action = btn.getAttribute("data-action");
    const id = btn.getAttribute("data-id");
    if (!action || !id) return;

    if (action === "card-open") {
      e.preventDefault();
      addToCart(id, +1);
      OPEN.add(id);
      syncCard(id);
      return;
    }

    if (action === "card-inc") {
      e.preventDefault();
      addToCart(id, +1);
      OPEN.add(id);
      syncCard(id);
      return;
    }

    if (action === "card-dec") {
      e.preventDefault();
      addToCart(id, -1);
      // If became 0, syncCard will collapse; otherwise keep open
      OPEN.add(id);
      syncCard(id);
      return;
    }
  });
}


// ---------- init ----------
init();

async function init() {
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());

  setLangUI();
  wireTopbar();
  wireQtyControls();

  await loadProducts();
  await loadZones();
  updateCartBadge();

  const last = getLastOrderId();
  if (last) startOrderPolling(last);

  window.addEventListener("hashchange", renderRoute);
  renderRoute();
}

// ---------- topbar ----------
function wireTopbar() {
  if (langRuBtn) langRuBtn.addEventListener("click", () => setLang("ru"));
  if (langEnBtn) langEnBtn.addEventListener("click", () => setLang("en"));
}

function setLang(next) {
  lang = next;
  localStorage.setItem(STORAGE.LANG, lang);
  setLangUI();
  renderRoute();
}

function setLangUI() {
  const t = I18N[lang];
  if (brandTagEl) brandTagEl.textContent = t.brandTag;
  if (footerMutedEl) footerMutedEl.textContent = t.footer;

  if (cartTextEl) cartTextEl.textContent = t.cart;
  const adminLink = $("#adminLink");
  const checkoutLink = $("#checkoutLink");
  if (adminLink) adminLink.textContent = t.admin;
  if (checkoutLink) checkoutLink.textContent = t.checkout;

  if (langRuBtn) langRuBtn.classList.toggle("is-active", lang === "ru");
  if (langEnBtn) langEnBtn.classList.toggle("is-active", lang === "en");
}

// ---------- routing ----------
function renderRoute() {
  const { path, params } = parseHash();

  switch (path) {
    case "/":
      renderCatalog();
      break;

    case "/category":
      renderCategoryPage(params.name);
      break;

    case "/product":
      renderProduct(params.id);
      break;

    case "/cart":
      renderCartPage();
      break;

    case "/checkout":
      renderCheckout();
      break;

    case "/orders":
      renderOrdersHistory();
      break;

    case "/courier":
      renderCourierDashboard();
      break;

    case "/admin":
      renderAdmin();
      break;

    default:
      location.hash = "#/";
  }
}

function parseHash() {
  const h = (location.hash || "#/").replace(/^#/, "");
  const parts = h.split("/").filter(Boolean);

  if (parts.length === 0) return { path: "/", params: {} };

  if (parts[0] === "product" && parts[1])
    return { path: "/product", params: { id: decodeURIComponent(parts[1]) } };

  if (parts[0] === "category" && parts[1])
    return { path: "/category", params: { name: decodeURIComponent(parts[1]) } };

  return { path: "/" + parts[0], params: {} };
}






// ---------- ORDER: last id + polling ----------
function setLastOrderId(id) {
  localStorage.setItem(STORAGE2.LAST_ORDER, String(id || ""));
  if (id) startOrderPolling(id);
}

function getLastOrderId() {
  return String(localStorage.getItem(STORAGE2.LAST_ORDER) || "").trim() || "";
}

function stopOrderPolling() {
  if (orderPollTimer) clearInterval(orderPollTimer);
  orderPollTimer = null;
  orderPollId = null;
}

function setOrderWidget({ id, status, updatedAt }) {
  if (orderIdEl) orderIdEl.textContent = id || "—";
  if (orderStatusEl) orderStatusEl.textContent = statusLabel(status, lang);
  if (orderUpdatedEl) {
    orderUpdatedEl.textContent = updatedAt
      ? new Date(updatedAt).toLocaleString(lang === "ru" ? "ru-RU" : "en-US")
      : "—";
  }
}

// ✅ robust public order fetch (supports many server formats)
async function fetchOrderPublic(id) {
  const url = `${API_BASE}/api/orders/public/${encodeURIComponent(id)}`;
  const r = await fetch(url, { cache: "no-store" });

  const text = await r.text();
  let data = null;
  try {
    data = text ? JSON.parse(text) : null;
  } catch {
    data = null;
  }

  if (!r.ok) {
    const msg = (data && (data.error || data.message)) || text || `HTTP ${r.status}`;
    throw new Error(msg);
  }

  const raw = (data && (data.order || data.data?.order || data)) || {};
  return {
    id: String(raw.id || raw.orderId || raw.order_id || id),
    status: String(raw.status || raw.state || raw.stage || "NEW"),
    createdAt: raw.createdAt || raw.created_at || null,
    updatedAt: raw.updatedAt || raw.updated_at || raw.updated || null,
    totals: raw.totals || raw.total || { grandTotal: raw.grandTotal || 0 },
    items: raw.items || [],
  };
}

function startOrderPolling(id) {
  if (!id) return;
  if (orderPollId === id && orderPollTimer) return;

  stopOrderPolling();
  orderPollId = id;

  (async () => {
    try {
      const o = await fetchOrderPublic(id);
      setOrderWidget({
        id: o.id,
        status: o.status,
        updatedAt: o.updatedAt || o.createdAt,
      });
    } catch {
      setOrderWidget({ id, status: "—", updatedAt: "" });
    }
  })();

  orderPollTimer = setInterval(async () => {
    try {
      const o = await fetchOrderPublic(id);
      setOrderWidget({
        id: o.id,
        status: o.status,
        updatedAt: o.updatedAt || o.createdAt,
      });
      if (location.hash.startsWith("#/orders")) renderOrdersHistory();
    } catch {
      // ignore
    }
  }, 4000);
}
function rub(v) {
  const n = Number(v || 0);
  const currency = (I18N?.[lang]?.currency) || "₽";

  try {
    const locale = lang === "ru" ? "ru-RU" : "en-US";
    const formatted = new Intl.NumberFormat(locale).format(n);
    return `${formatted} ${currency}`;
  } catch {
    return `${n} ${currency}`;
  }
}

function renderCard(p) {

  const t = I18N[lang];

  const name = escapeHtml(lang === "ru" ? p.name_ru : p.name_en);
  const desc = escapeHtml(lang === "ru" ? p.desc_ru : p.desc_en);
  const cat = escapeHtml(lang === "ru" ? p.cat_ru : p.cat_en);

  const topPrice = rub(p.price);
  const img = p.icon3d || p.image || "";
  const imgHtml = img
    ? `<img class="card__img" src="${escapeAttr(img)}" alt="${name}" loading="lazy" />`
    : `<div class="card__emoji" aria-hidden="true">${escapeHtml(p.emoji || "🛍️")}</div>`;

  // NOTE:
  // - On cards we use "marketplace" UX:
  //   default: single [+]
  //   after tap: shows [- qty +]
  //   on scroll: collapses back to single [+] (qty is kept in cart)
  return `
    <article class="card ${p.hot ? "card--hot" : ""}" data-card-id="${escapeAttr(p.id)}">
      <div class="card__top">
        ${p.hot ? `<span class="pill pill--hot">HOT</span>` : `<span class="pill pill--cat">${cat || "&nbsp;"}</span>`}
        <span class="pill pill--price">${topPrice}</span>
      </div>

      <div class="card__mid">
        <div class="card__imgWrap">${imgHtml}</div>
        <h3 class="card__title">${name}</h3>
        <div class="card__desc">${desc}</div>
      </div>

      <div class="card__foot">
        <div class="card__priceBlock">
          <div class="card__price">${topPrice}</div>
          <div class="card__per">${t.perPiece || ""}</div>
        </div>

        <div class="card__controls" data-qty-root data-id="${escapeAttr(p.id)}">
          <button class="addBtn" type="button" data-action="card-open" data-id="${escapeAttr(p.id)}" aria-label="${t.add}">
            +
          </button>

          <div class="stepper stepper--card" data-stepper hidden>
            <button class="stepper__btn" type="button" data-action="card-dec" data-id="${escapeAttr(p.id)}" aria-label="${t.minus}">
              −
            </button>
            <span class="stepper__qty" data-qty-for="${escapeAttr(p.id)}">0</span>
            <button class="stepper__btn" type="button" data-action="card-inc" data-id="${escapeAttr(p.id)}" aria-label="${t.plus}">
              +
            </button>
          </div>
        </div>
      </div>
    </article>
  `;
}


// ---------- catalog ----------
