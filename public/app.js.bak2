function statusLabel(s, lang) {
  const map = {
    NEW: { ru: "НОВЫЙ", en: "NEW" },
    ACCEPTED: { ru: "ПРИНЯТ", en: "ACCEPTED" },
    PICKING: { ru: "СОБИРАЕМ", en: "PICKING" },
    ON_THE_WAY: { ru: "В ПУТИ", en: "ON THE WAY" },
    DONE: { ru: "ДОСТАВЛЕН", en: "DONE" },
    CANCELED: { ru: "ОТМЕНЁН", en: "CANCELED" },
  };
  return (map[s] && map[s][lang]) || s || "—";
}

