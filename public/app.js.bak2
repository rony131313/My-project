"use strict";

/**
 * 67 — SPA (fixed)
 * - robust /api/order parsing
 * - robust /api/orders/public/:id parsing
 * - always shows real errors
 * - clears cart + redirects to /orders on success
 */

// API base:
// - Production: site + API served from the same origin => use "" (no CORS issues)
// - Local dev: if you open the site from a different port (e.g. 5500), fallback to localhost:8080
const API_BASE = (() => {
  const isLocalhost = location.hostname === "localhost" || location.hostname === "127.0.0.1";
  const isApiPort = String(location.port || "") === "8080";
  // If we're not on the API port (e.g. Live Server), point to the API.
  if (isLocalhost && !isApiPort) return "http://localhost:8080";
  // Otherwise, use same-origin.
  return "";
})();
window.API_BASE = API_BASE;

